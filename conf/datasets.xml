<!-- GROUP A: 2D EUROPE PRODUCTS                                   -->
<!-- ============================================================ -->

<!-- 1. SST - 1km native L4 -->
<dataset type="EDDGridFromNcFiles" datasetID="unified_europe_sst" active="true">
    <reloadEveryNMinutes>1440</reloadEveryNMinutes>
    <updateEveryNMillis>10000</updateEveryNMillis>
    <fileDir>/datasets/unified_europe_sst/</fileDir>
    <fileNameRegex>EUROPE_TOTAL_1KM_sst_\d{6,8}(_\d{2})?\.nc</fileNameRegex>
    <recursive>false</recursive>
    <metadataFrom>last</metadataFrom>
    <matchAxisNDigits>20</matchAxisNDigits>
    <fileTableInMemory>false</fileTableInMemory>
    <accessibleViaFiles>true</accessibleViaFiles>
    <addAttributes>
        <att name="title">Unified Europe SST - 1km (MED/ATL/BAL/BS L4 Mosaic)</att>
        <att name="institution">SARTI - DEGI4ECO Project</att>
        <att name="infoUrl">https://sarti.upc.edu/degi4eco</att>
        <att name="summary">Monthly SST at 1km native resolution. Sources: CMEMS MED, ATL, BAL, BS L4 + OSTIA fallback.</att>
        <att name="cdm_data_type">Grid</att>
        <att name="sourceUrl">(local files)</att>
    </addAttributes>
    <axisVariable><sourceName>time</sourceName><destinationName>time</destinationName><addAttributes/></axisVariable>
    <axisVariable><sourceName>lat</sourceName><destinationName>latitude</destinationName><addAttributes/></axisVariable>
    <axisVariable><sourceName>lon</sourceName><destinationName>longitude</destinationName><addAttributes/></axisVariable>
    <dataVariable>
        <sourceName>analysed_sst</sourceName><destinationName>sst</destinationName><dataType>float</dataType>
        <addAttributes><att name="add_offset" type="double">-273.15</att><att name="units">degree_Celsius</att><att name="colorBarMinimum" type="double">-2.0</att><att name="colorBarMaximum" type="double">32.0</att><att name="colorBarPalette">KT_thermal</att></addAttributes>
    </dataVariable>
    <dataVariable><sourceName>prediction_flag</sourceName><destinationName>prediction_flag</destinationName><dataType>byte</dataType><addAttributes><att name="flag_values" type="byteList">0 1</att><att name="flag_meanings">historical_data future_prediction</att></addAttributes></dataVariable>
</dataset>

